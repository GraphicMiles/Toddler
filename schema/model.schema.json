{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://toddler.ai/schema/model.schema.json",
  "title": "Toddler model catalog entry",
  "type": "object",
  "additionalProperties": false,
  "required": ["id", "name", "task", "family", "sizeBytes", "paramCount", "minRamGb", "minVramGb", "minDiskGb", "runsOn", "trainerRuntime", "license", "downloadUrl", "benchmarkAccuracy"],
  "properties": {
    "id": { "type": "string", "minLength": 1 },
    "name": { "type": "string", "minLength": 1 },
    "task": { "type": "string", "minLength": 1 },
    "family": { "type": "string", "minLength": 1 },
    "sizeBytes": { "type": "integer", "minimum": 0 },
    "paramCount": { "type": "integer", "minimum": 0 },
    "minRamGb": { "type": "number", "minimum": 0 },
    "minVramGb": { "type": "number", "minimum": 0 },
    "minDiskGb": { "type": "number", "minimum": 0 },
    "runsOn": { "type": "array", "minItems": 1, "uniqueItems": true, "items": { "enum": ["mobile", "desktop", "cloud"] } },
    "trainerRuntime": { "type": "string", "minLength": 1 },
    "license": { "type": "string", "minLength": 1 },
    "downloadUrl": { "type": ["string", "null"], "format": "uri" },
    "benchmarkAccuracy": { "type": ["number", "null"], "minimum": 0, "maximum": 1 }
  }
}
